def run_system(user_info):
    name = user_info['name']
    speak("Welcome to FAIROS Empire Mix")
    
    print()
    
    for i in range(1, 6):
        sys.stdout.write(f'\r{G} ┌──({C}FAIROS CORE{G})➤{N}')
        sys.stdout.write(f'\n\r{G} └─$ {Y}System Launching: {R}{i}{N}   ')
        sys.stdout.flush()
        time.sleep(0.5)
    
    print()
    print(f"{G}============================================================{N}")
    
    msg = f"Welcome to FAIROS tool setup - Empire Mix is ready, {name}"
    idx = 0
    for char in msg:
        sys.stdout.write(rainbow[idx % len(rainbow)] + char)
        sys.stdout.flush()
        idx += 1
        time.sleep(0.02)
    print(N)
    speak(f"Welcome {name}")
    
    print(f"{G}============================================================{N}")
    
    for i in range(3):
        sys.stdout.write(f'\r{G}   SYSTEM ACTIVATED SUCCESSFULLY   {N}')
        sys.stdout.flush()
        time.sleep(0.3)
    
    print()
    print(f"{G}============================================================{N}")
    print()
    
    matrix_rain_fast()

def show_ports():
    print(f"{C}[+] المنافذ المفتوحة:{N}")
    os.system('netstat -tuln 2>/dev/null | grep LISTEN | head -3')
    print()

def show_prompt(user_info):
    name = user_info['name']
    print(f"{G}┌──({C}FAIROS • {name}{G})➤({P}الامبريتري ميكس{G})")
    print(f"└─{W}$ {N}", end='')
    sys.stdout.flush()


def setup_permissions():
    try:
        os.system('termux-setup-storage > /dev/null 2>&1')
        os.system('chmod -R 777 /data/data/com.termux/files/home 2>/dev/null')
    except:
        pass


def main():
    try:
        setup_permissions()
        user_info = get_user_info()
        show_logo(user_info)
        run_system(user_info)
        show_ports()
        show_prompt(user_info)
        
        os.environ['PS1'] = ''
        
    except KeyboardInterrupt:
        print(f"\n{R}[!] تم ايقاف الاداة{N}")
    except Exception as e:
        print(f"{R}[!] خطأ: {e}{N}")

if __name__ == "__main__":
    main()

# ============================================================
# دالة النطق
# ============================================================

def speak(text):
    try:
        os.system(f'espeak -v en -p 50 -s 150 "{text}" 2>/dev/null &')
    except:
        pass

# ============================================================
# دوائر متحركة
# ============================================================

def animated_circles():
    circles = ['◐', '◑', '◒', '◓', '◔', '◕', '◖', '◗']
    for i in range(12):
        sys.stdout.write(f'\r{G}   {circles[i%8]} {circles[(i+2)%8]} {circles[(i+4)%8]} {circles[(i+6)%8]}   {N}')
        sys.stdout.flush()
        time.sleep(0.05)

# ============================================================
# مصفوفة المطر
# ============================================================

def matrix_rain():
    for i in range(15):
        line = ""
        for j in range(50):
            line += random.choice(['0', '1'])
        print(G + line + N)
        time.sleep(0.03)

def matrix_rain_fast():
    for i in range(8):
        line = ""
        for j in range(50):
            line += random.choice(['0', '1'])
        print(G + line + N)
        time.sleep(0.02)


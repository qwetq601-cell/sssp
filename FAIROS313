def get_user_info():
    if os.path.exists(INFO_FILE):
        with open(INFO_FILE, 'r', encoding='utf-8') as f:
            return json.load(f)
    
    os.system('clear')
    matrix_rain()
    time.sleep(0.5)
    os.system('clear')
    
    print(f"{C}============================================================{N}")
    print(f"{C}              الاداة الاسطورية - الامبريتري ميكس             {N}")
    print(f"{C}============================================================{N}\n")
    
    print(f"{G}┌──({C}FAIROS{G})➤{N}")
    print(f"{G}└─$ {W}ادخل اسمك: {N}", end='')
    user_name = input().strip()
    if not user_name:
        user_name = "FAIROS"
    
    print(f"{G}┌──({C}FAIROS{G})➤{N}")
    print(f"{G}└─$ {W}ادخل معرف تليجرام: {N}", end='')
    tg_user = input().strip()
    if not tg_user:
        tg_user = "@Unknown"
    elif not tg_user.startswith('@'):
        tg_user = '@' + tg_user
    
    print(f"{G}┌──({C}FAIROS{G})➤{N}")
    print(f"{G}└─$ {W}ادخل قناة تليجرام: {N}", end='')
    tg_channel = input().strip()
    if not tg_channel:
        tg_channel = "@None"
    elif not tg_channel.startswith('@'):
        tg_channel = '@' + tg_channel
    
    info = {
        'name': user_name,
        'telegram': tg_user,
        'channel': tg_channel,
        'date': time.strftime('%Y-%m-%d %H:%M:%S')
    }
    
    with open(INFO_FILE, 'w', encoding='utf-8') as f:
        json.dump(info, f, ensure_ascii=False, indent=2)
    
    return info


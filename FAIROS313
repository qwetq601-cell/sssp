# ============================================================
# الوان
# ============================================================

R = '\033[0;31m'
G = '\033[0;32m'
Y = '\033[1;33m'
B = '\033[0;34m'
P = '\033[0;35m'
C = '\033[0;36m'
W = '\033[1;37m'
N = '\033[0m'

rainbow = [R, G, Y, B, P, C]

